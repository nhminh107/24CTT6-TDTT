# Firebase Configuration (Lấy từ Firebase Console -> Project Settings)
NEXT_PUBLIC_FIREBASE_API_KEY=điền_apiKey_vào_đây
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=điền_sender_id_vào_đây
NEXT_PUBLIC_FIREBASE_APP_ID=điền_app_id_vào_đây

# Google Auth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=điền_client_id_vào_đây

# Cloudinary unsigned upload
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=điền_cloud_name_vào_đây
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=điền_upload_preset_vào_đây

# Goong Maps
NEXT_PUBLIC_GOONG_API_KEY=điền_goong_api_key_vào_đây
NEXT_PUBLIC_GOONG_MAP_API_KEY=điền_goong_map_api_key_vào_đây
