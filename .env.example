# --- PHẦN XÁC THỰC (AUTH) ---
# Firebase Admin (Dành cho Server kiểm tra Token)
FIREBASE_WEB_API_KEY=điền_firebase_web_api_key_vào_đây

# Google OAuth
GOOGLE_CLIENT_ID=điền_client_id_vào_đây
GOOGLE_CLIENT_SECRET=điền_client_secret_vào_đây

# --- PHẦN TRÍ TUỆ NHÂN TẠO (AI) ---
# API AI Gemini (Dùng GEMINI_API để khớp với code Python)
GEMINI_API=điền_gemini_api_key_vào_đây

# API Groq
GROQ_API_KEY=điền_groq_api_key_vào_đây
GROQ_API_KEY_MAIN=điền_groq_api_key_main_vào_đây

# --- PHẦN BẢN ĐỒ & ĐỊA ĐIỂM (MAPS) ---
# API LocationIQ (Nếu dùng thay thế Goong)
LOCATIONIQ_API_KEY=điền_locationiq_api_key_vào_đây

# API Goong (Nếu code vẫn gọi tới Goong)
GOONG_API_KEY=điền_goong_api_key_vào_đây
